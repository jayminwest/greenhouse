{
	"name": "@os-eco/greenhouse-cli",
	"version": "0.1.1",
	"description": "Autonomous development daemon — polls GitHub, dispatches overstory runs, opens PRs",
	"author": "Jaymin West",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/jayminwest/greenhouse.git"
	},
	"homepage": "https://github.com/jayminwest/greenhouse",
	"keywords": [
		"ai",
		"agents",
		"automation",
		"github",
		"overstory",
		"cli",
		"developer-tools"
	],
	"bin": {
		"greenhouse": "./src/cli.ts",
		"grhs": "./src/cli.ts"
	},
	"main": "src/cli.ts",
	"files": [
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.0"
	},
	"scripts": {
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"version:bump": "bun scripts/version-bump.ts"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/bun": "latest",
		"typescript": "^5.9.0"
	}
}
