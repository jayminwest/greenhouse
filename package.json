{
	"name": "@os-eco/greenhouse-cli",
	"version": "0.1.0",
	"description": "Autonomous development daemon for AI agent workflows",
	"type": "module",
	"bin": {
		"greenhouse": "./src/cli.ts",
		"grhs": "./src/cli.ts"
	},
	"main": "src/cli.ts",
	"files": ["src"],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.0.0"
	},
	"keywords": ["ai", "agents", "automation", "github", "cli", "developer-tools"],
	"author": "Jaymin West",
	"license": "MIT",
	"homepage": "https://github.com/jayminwest/greenhouse",
	"bugs": {
		"url": "https://github.com/jayminwest/greenhouse/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jayminwest/greenhouse.git"
	},
	"scripts": {
		"test": "bun test",
		"lint": "bunx biome check .",
		"typecheck": "tsc --noEmit",
		"version:bump": "bun run scripts/version-bump.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "latest",
		"typescript": "^5.0.0"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3"
	}
}
